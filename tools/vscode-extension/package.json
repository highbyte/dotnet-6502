{
  "name": "dotnet-6502-debugger",
  "displayName": "6502 Debugger for dotnet-6502",
  "version": "0.1.0",
  "publisher": "highbyte",
  "description": "Debug 6502 machine code programs using the dotnet-6502 emulator",
  "author": {
    "name": "highbyte"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:dotnet6502",
    "onDebugDynamicConfigurations:dotnet6502"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotnet6502.generateBuildTask",
        "title": "Generate C64 Build Task (ca65)"
      },
      {
        "command": "dotnet6502.generateLaunchConfig",
        "title": "Generate Launch Config (DotNet6502)"
      },
      {
        "command": "dotnet6502.viewMemory",
        "title": "View Memory",
        "icon": "$(symbol-array)"
      }
    ],
    "menus": {
      "debug/toolBar": [
        {
          "command": "dotnet6502.viewMemory",
          "when": "debugType == 'dotnet6502'",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .asm",
          "command": "dotnet6502.generateBuildTask",
          "group": "2_workspace@1"
        },
        {
          "when": "resourceExtname == .asm",
          "command": "dotnet6502.generateLaunchConfig",
          "group": "2_workspace@2"
        }
      ]
    },
    "languages": [
      {
        "id": "asm",
        "aliases": ["Assembly", "asm"],
        "extensions": [".asm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "breakpoints": [
      {
        "language": "asm"
      },
      {
        "language": "kickass"
      },
      {
        "language": "acme"
      },
      {
        "language": "ca65"
      },
      {
        "language": "dasm"
      }
    ],
    "debuggers": [
      {
        "type": "dotnet6502",
        "label": "dotnet-6502 Debugger",
        "languages": ["asm", "kickass", "acme", "ca65", "dasm"],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .prg file to debug (optional if buildSourceFile is specified, will use <basename>.prg)",
                "default": "${workspaceFolder}/program.prg"
              },
              "dbgFile": {
                "type": "string",
                "description": "Path to ca65 .dbg file for source-level debugging (optional, will use <basename>.dbg if buildEnabled)",
                "default": null
              },
              "loadAddress": {
                "type": "number",
                "description": "Override load address (optional, normally read from .prg file)",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "stopOnBRK": {
                "type": "boolean",
                "description": "Automatically stop when BRK instruction is encountered",
                "default": true
              },
              "debugServer": {
                "type": "number",
                "description": "TCP port number to connect to an existing debug adapter server (e.g., running emulator host app with --debug-port)",
                "default": null
              },
              "emulatorExecutable": {
                "type": "string",
                "description": "Path or name of the executable to use for debugging. Default depends on debugAdapter mode: for 'minimal', defaults to 'Highbyte.DotNet6502.DebugAdapter.ConsoleApp[.exe]'; for 'emulator', defaults to 'Highbyte.DotNet6502.App.Avalonia.Desktop[.exe]' (currently the only supported emulator host). Resolved by checking the system PATH first, then repo-relative build output paths. Can also be set to a full path.",
                "default": null
              },
              "system": {
                "type": "string",
                "description": "System to start in emulator host (e.g., 'C64')",
                "default": "C64"
              },
              "systemVariant": {
                "type": "string",
                "description": "System variant to use (optional, uses first variant if not specified)",
                "default": null
              },
              "debugPort": {
                "type": "number",
                "description": "TCP port for debug adapter server (used when debugAdapter is 'emulator')",
                "default": 4711
              },
              "startupTimeout": {
                "type": "number",
                "description": "Timeout in seconds to wait for emulator host TCP server to start (default 120, increase if using DOTNET6502_WAIT_FOR_DEBUGGER)",
                "default": 120
              },
              "waitForSystemReady": {
                "type": "boolean",
                "description": "Wait for system to be ready before connecting debugger",
                "default": true
              },
              "loadProgram": {
                "type": "boolean",
                "description": "Automatically load the program file into memory",
                "default": true
              },
              "runProgram": {
                "type": "boolean",
                "description": "Automatically run the loaded program (sets PC to load address)",
                "default": false
              }
            }
          },
          "attach": {
            "required": ["debugServer"],
            "properties": {
              "debugServer": {
                "type": "number",
                "description": "TCP port number to connect to the emulator host debug adapter server"
              },
              "program": {
                "type": "string",
                "description": "Path to the .prg file being debugged",
                "default": "${workspaceFolder}/program.prg"
              },
              "dbgFile": {
                "type": "string",
                "description": "Path to ca65 .dbg file for source-level debugging",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after attaching",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "dotnet6502",
            "request": "launch",
            "name": "Debug 6502 Program (dotnet-6502)",
            "program": "${workspaceFolder}/program.prg",
            "stopOnEntry": true
          },
          {
            "type": "dotnet6502",
            "request": "attach",
            "name": "Attach to Emulator Host (dotnet-6502)",
            "debugServer": 4711,
            "program": "${workspaceFolder}/program.prg",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "dotnet-6502: Launch",
            "description": "A new configuration for debugging a 6502 program with dotnet-6502",
            "body": {
              "type": "dotnet6502",
              "request": "launch",
              "name": "Debug 6502 Program (dotnet-6502)",
              "program": "^\"\\${workspaceFolder}/program.prg\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "dotnet-6502: Attach",
            "description": "Attach to a running emulator host app with debug adapter enabled",
            "body": {
              "type": "dotnet6502",
              "request": "attach",
              "name": "Attach to Emulator Host (dotnet-6502)",
              "debugServer": 4711,
              "program": "^\"\\${workspaceFolder}/program.prg\"",
              "stopOnEntry": true
            }
          },
          {
            "label": "dotnet-6502: Launch Emulator",
            "description": "Launch emulator host app and attach debugger. Currently only Avalonia Desktop is supported.",
            "body": {
              "type": "dotnet6502",
              "request": "launch",
              "name": "Launch Emulator Host (dotnet-6502)",
              "program": "^\"\\${workspaceFolder}/program.prg\"",
              "stopOnEntry": true,
              "debugAdapter": "emulator",
              "system": "C64",
              "debugPort": 4711,
              "waitForSystemReady": true,
              "loadProgram": true,
              "runProgram": false
            }
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "ca65",
        "required": [],
        "properties": {}
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  }
}
