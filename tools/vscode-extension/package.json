{
  "name": "dotnet-6502-debugger",
  "displayName": "6502 Debugger for dotnet-6502",
  "version": "0.1.0",
  "publisher": "highbyte",
  "description": "Debug 6502 machine code programs using the dotnet-6502 emulator",
  "author": {
    "name": "highbyte"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:dotnet6502",
    "onDebugDynamicConfigurations:dotnet6502",
    "workspaceContains:**/*.asm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "asm",
        "aliases": ["Assembly", "asm"],
        "extensions": [".asm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "breakpoints": [
      {
        "language": "asm"
      },
      {
        "language": "kickass"
      },
      {
        "language": "acme"
      },
      {
        "language": "ca65"
      },
      {
        "language": "dasm"
      }
    ],
    "debuggers": [
      {
        "type": "dotnet6502",
        "label": "dotnet-6502 Debugger",
        "languages": ["asm", "kickass", "acme", "ca65", "dasm"],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .prg file to debug (optional if buildSourceFile is specified, will use <basename>.prg)",
                "default": "${workspaceFolder}/program.prg"
              },
              "dbgFile": {
                "type": "string",
                "description": "Path to ca65 .dbg file for source-level debugging (optional, will use <basename>.dbg if buildEnabled)",
                "default": null
              },
              "loadAddress": {
                "type": "number",
                "description": "Override load address (optional, normally read from .prg file)",
                "default": null
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Automatically stop after launch",
                "default": true
              },
              "stopOnBRK": {
                "type": "boolean",
                "description": "Automatically stop when BRK instruction is encountered",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "dotnet6502",
            "request": "launch",
            "name": "Debug 6502 Program (dotnet-6502)",
            "program": "${workspaceFolder}/program.prg",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "dotnet-6502: Launch",
            "description": "A new configuration for debugging a 6502 program with dotnet-6502",
            "body": {
              "type": "dotnet6502",
              "request": "launch",
              "name": "Debug 6502 Program (dotnet-6502)",
              "program": "^\"\\${workspaceFolder}/program.prg\"",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "ca65",
        "required": [],
        "properties": {
          "task": {
            "type": "string",
            "description": "The build task type (e.g., build-current-file)"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "ca65",
        "owner": "ca65",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.*)\\((\\d+)\\):\\s+(Error|Warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  }
}
