{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build test-program.asm (C64)",
      "type": "shell",
      "command": "cl65",
      "args": [
        "-g",
        "test-program.asm",
        "-o",
        "test-program.prg",
        "-C",
        "c64-asm.cfg",
        "--start-addr",
        "0xc000",
        "-Wl",
        "-Ln,test-program.lbl",
        "-Wl",
        "--dbgfile,test-program.dbg",
        "-Wl",
        "-m,test-program.map"
      ],
      "options": {
        "cwd": "/Users/highbyte/source/repos/dotnet-6502/tools/vscode-extension-test"
      },
      "problemMatcher": "$ca65",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Clean build outputs",
      "type": "shell",
      "command": "rm",
      "args": [
        "-f",
        "*.prg",
        "*.lbl",
        "*.dbg",
        "*.map"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}