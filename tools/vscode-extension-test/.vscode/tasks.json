{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build test-program",
      "type": "shell",
      "command": "cl65",
      "args": [
        "-g",
        "test-program.asm",
        "-o",
        "test-program.prg",
        "-C",
        "c64-asm.cfg",
        "--start-addr",
        "0x0600",
        "-Wl",
        "-Ln,test-program.lbl",
        "-Wl",
        "--dbgfile,test-program.dbg",
        "-Wl",
        "-m,test-program.map"
      ],
      "problemMatcher": {
        "owner": "ca65",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*)\\((\\d+)\\):\\s+(Error|Warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
