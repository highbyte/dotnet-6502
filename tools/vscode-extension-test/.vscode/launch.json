{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.asm (with preLaunchTask)",
      // Task "ca65: build current file (C64)" is auto-provided by the Task Provider - no tasks.json needed!
      // Open test-program.asm before pressing F5
      // program and dbgFile are auto-derived from the built file
      // IMPORTANT: test-program.asm must have .org directive to set load address
      "preLaunchTask": "ca65: build current file (C64)",
      "stopOnEntry": true,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.bin with .dbg load address",
      "program": "${workspaceFolder}/test-program.bin",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.prg (C64) with built-in load address",
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true
    }
  ]
}
