{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Launch Simple Emulator Host to Source Debug test-program.asm",
      "preLaunchTask": "Build test-program.asm (C64)",
      "stopOnEntry": true,
      "stopOnBRK": true,
      // Uses minimal debug adapter by default (debugAdapter: "minimal")
    },
    // {
    //   "type": "dotnet6502",
    //   "request": "launch",
    //   "name": "Launch Simple Emulator Host to Source Debug test-program.asm (via .dbg info)",
    //   "program": "${workspaceFolder}/test-program.bin",
    //   "dbgFile": "${workspaceFolder}/test-program.dbg",
    //   "stopOnEntry": true,
    //   "stopOnBRK": true
    //   // Uses minimal debug adapter by default (debugAdapter: "minimal")
    // },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Launch Simple Emulator Host to Source Debug test-program.asm (via .dbg info)",
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true
      // Uses minimal debug adapter by default (debugAdapter: "minimal")
    },
    {
      "type": "dotnet6502",
      "request": "attach",
      "name": "Attach to Full Emulator Host (TCP debug adapter) to Source Debug test-program.prg (via .dbg info)",
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true
      // Uses TCP connection to already-running emulator host app.
      // Currently only Avalonia Desktop (Highbyte.DotNet6502.App.Avalonia.Desktop) is supported.
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Launch Full Emulator Host with C64 to Source Debug smooth_scroller_and_raster2.asm",
      "preLaunchTask": "Build smooth_scroller_and_raster2.asm (C64)",
      "debugAdapter": "emulator",
      "system": "C64",
      "waitForSystemReady": true,
      "loadProgram": true,
      "runProgram": true,
      "stopOnEntry": false,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Launch Full Emulator Host with C64 to Disassembly Debug smooth_scroller_and_raster.prg (without .asm source)",
      // Uses emulator host app as debug adapter (full emulation support).
      // Currently only Avalonia Desktop (Highbyte.DotNet6502.App.Avalonia.Desktop) is supported.
      "debugAdapter": "emulator",

      "program": "${workspaceFolder}/../../samples/Assembler/C64/Raster/Build/smooth_scroller_and_raster.prg",

      // Emulator host configuration:
      // "emulatorExecutable" defaults to "Highbyte.DotNet6502.App.Avalonia.Desktop[.exe]" (assumes it's in system PATH).
      // Override with a full path if not in PATH, e.g.:
      //"emulatorExecutable": "${userHome}/source/repos/dotnet-6502/src/apps/Avalonia/Highbyte.DotNet6502.App.Avalonia.Desktop/bin/Debug/net10.0/Highbyte.DotNet6502.App.Avalonia.Desktop.exe",
      "system": "C64",
      "waitForSystemReady": true,
      "loadProgram": true,
      "runProgram": false,
      "stopOnEntry": true,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug C64 KERNAL Boot",
      "debugAdapter": "emulator",
      "system": "C64",
      "stopOnEntry": true,
      "loadProgram": false,
      "waitForSystemReady": false
    }
  ]
}