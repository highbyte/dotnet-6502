{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.asm",
      "preLaunchTask": "Build test-program.asm (C64)",
      "stopOnEntry": true,
      "stopOnBRK": true,
      // Uses console debug adapter by default (debugAdapter: "console")
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.bin with .dbg load address",
      "program": "${workspaceFolder}/test-program.bin",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.prg (C64) with built-in load address",
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true
    },
    {
      "type": "dotnet6502",
      "request": "attach",
      "name": "Attach to Avalonia Desktop (TCP debug adapter)",
      "debugServer": 4711,
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true
      // Uses TCP connection to already-running Avalonia Desktop app
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Launch Avalonia Desktop C64 with test-program.asm",
      "preLaunchTask": "Build test-program.asm (C64)",
      "env": {
        "DOTNET6502_WAIT_FOR_DEBUGGER": "true"
      },

      // Uses Avalonia Desktop app as debug adapter (full emulation support)
      "debugAdapter": "avalonia",

      // Avalonia-specific configuration:
      "avaloniaExecutable": "${userHome}/source/repos/dotnet-6502/src/apps/Avalonia/Highbyte.DotNet6502.App.Avalonia.Desktop/bin/Debug/net10.0/Highbyte.DotNet6502.App.Avalonia.Desktop",
      "windows": {
        "avaloniaExecutable": "${userHome}/source/repos/dotnet-6502/src/apps/Avalonia/Highbyte.DotNet6502.App.Avalonia.Desktop/bin/Debug/net10.0/Highbyte.DotNet6502.App.Avalonia.Desktop.exe"
      },
      "avaloniaDebugPort": 4711,
      "avaloniaStartupTimeout": 300,
      "avaloniaSystem": "C64",
      "avaloniaWaitForReady": true,
      "avaloniaLoadPrg": true,
      "avaloniaRunProgram": false,
      "stopOnEntry": true,
      "stopOnBRK": true,
    }
  ]
}