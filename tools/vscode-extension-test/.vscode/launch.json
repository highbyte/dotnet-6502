{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.prg (dotnet-6502)",
      "program": "${workspaceFolder}/test-program.prg",
      "stopOnEntry": true,
      "stopOnBRK": true,
      "preLaunchTask": "Build test-program"
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug with source-level (test-program.dbg)",
      "program": "${workspaceFolder}/test-program.prg",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true,
      "preLaunchTask": "Build test-program"
    },
    {
      "type": "dotnet6502",
      "request": "launch",
      "name": "Debug test-program.bin with .dbg load address",
      "program": "${workspaceFolder}/test-program.bin",
      "dbgFile": "${workspaceFolder}/test-program.dbg",
      "stopOnEntry": true,
      "stopOnBRK": true,
      "preLaunchTask": "Build test-program"
    }
  ]
}
