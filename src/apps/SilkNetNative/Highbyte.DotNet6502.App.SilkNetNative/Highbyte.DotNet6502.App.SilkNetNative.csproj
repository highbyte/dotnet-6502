<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!--
    Thin entry exe (composition root): only Program.cs. The host-app library, UI and all host-tech
    Impl references live in App.SilkNetNative.Core. The per-system shells are referenced here so
    their engine-plugin DLL closure is deployed into this app's output for SystemPluginDiscovery.
    The shells use a convention glob (App.SilkNetNative.Shell.*) so adding a new system needs no
    edit to this entry exe.
  -->
  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.App.SilkNetNative.Core\Highbyte.DotNet6502.App.SilkNetNative.Core.csproj" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\Highbyte.DotNet6502.App.SilkNetNative.Shell.*\*.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Linux native assets must be explicitly included on the deployed exe (Win32/macOS are
         transitive dependencies of SkiaSharp). -->
    <PackageReference Include="SkiaSharp.NativeAssets.Linux" />
  </ItemGroup>

  <!--
    Plug-in discovery manifest (single-file publish).
    SystemPluginDiscovery loads plug-in assemblies by (a) a transitive reference walk from the
    entry assembly, (b) a scan of the output directory, and (c) an assembly-metadata manifest.
    With PublishSingleFile=true (the publish path for this exe) the plug-in DLLs are bundled
    inside the single-file exe, so (b) finds nothing; and the entry exe holds no static
    reference to any per-system plug-in type, so the C# compiler prunes the ProjectReferences
    and (a) finds nothing either.
    This target emits, into the entry assembly, one
    [assembly: AssemblyMetadata("Highbyte.DotNet6502.PluginAssembly", "<name>")] per
    Highbyte.DotNet6502.* assembly in the resolved reference closure (direct + transitive).
    SystemPluginDiscovery reads that manifest and Assembly.Loads each by name. Convention-based:
    adding a new system needs no edit here.
  -->
  <Target Name="EmitPluginAssemblyManifest"
          DependsOnTargets="ResolveReferences"
          BeforeTargets="GetAssemblyAttributes">
    <ItemGroup>
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferencePath.FileName)"
                        Condition="$([System.String]::Copy('%(ReferencePath.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferenceDependencyPaths.FileName)"
                        Condition="$([System.String]::Copy('%(ReferenceDependencyPaths.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <None Update="appsettings.Development.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </None>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
