{
  "Highbyte.DotNet6502.Scripting": {
    "Enabled": true,
    "MaxExecutionWarningMs": 5,
    "EnableScriptsAtStart": false,
    "AllowFileIO": true,
    "AllowFileWrite": true,
    "AllowHttpRequests": true,
    "AllowTcpClient": true,
    "AllowStore": true
  },

  "Highbyte.DotNet6502.HeadlessConfig": {
    "DefaultEmulator": "C64"
  },

  "Highbyte.DotNet6502.C64.Headless": {
    "SwiftLinkHost": {
      "TransportMode": "RawTcp",
      "TcpHost": "127.0.0.1",
      "TcpPort": 5000,
      "ConnectOnBoot": false
    },
    "SystemConfig": {
      "SwiftLink": {
        "Enabled": false,
        "CartridgeIOAddress": "DE00",
        "ReceiveMode": "Compatible"
      },
      "ROMs": [
        {
          "Name": "basic",
          "File": "basic.901226-01.bin"
        },
        {
          "Name": "kernal",
          "File": "kernal.901227-03.bin"
        },
        {
          "Name": "chargen",
          "File": "characters.901225-01.bin"
        }
      ],
      "AudioEnabled": false
    }
  },

  "Highbyte.DotNet6502.GenericComputer.Headless": {
    "SystemConfig": {
      "ExamplePrograms": {
        "Snake": "snake6502.prg",
        "Scroll": "hostinteraction_scroll_text_and_cycle_colors.prg",
        "HelloWorld": "hello_world.prg"
      }
    }
  }
}
