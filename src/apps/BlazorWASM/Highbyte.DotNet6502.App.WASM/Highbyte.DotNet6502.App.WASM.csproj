<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <RunAOTCompilation>true</RunAOTCompilation>
    
    <!--<PublishIISAssets>true</PublishIISAssets>-->

    <!--<BlazorEnableTimeZoneSupport>false</BlazorEnableTimeZoneSupport>
    <BlazorWebAssemblyPreserveCollationData>false</BlazorWebAssemblyPreserveCollationData>-->

    <Version>1.0</Version>
  </PropertyGroup>

  <!--In debug, make builds faster by reducing optimizations-->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <WasmNativeStrip>false</WasmNativeStrip>
    <EmccCompileOptimizationFlag>-O1</EmccCompileOptimizationFlag>
  </PropertyGroup>
  
  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.App.WASM.Core\Highbyte.DotNet6502.App.WASM.Core.csproj" />
    <!-- Convention glob: every per-system shell is deployed for SystemPluginDiscovery without
         editing this entry exe when a new system is added. NOTE: the TrimmerRootAssembly block
         below still lists shells/engine-plugins by name and must be extended for a new system. -->
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\Highbyte.DotNet6502.App.WASM.Shell.*\*.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.AspNet\Highbyte.DotNet6502.Impl.AspNet.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.Skia\Highbyte.DotNet6502.Impl.Skia.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Systems.Plugins\Highbyte.DotNet6502.Systems.Plugins.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Systems\Highbyte.DotNet6502.Systems.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502\Highbyte.DotNet6502.csproj" />
  </ItemGroup>

  <!--
    Plug-in assemblies are discovered only via [assembly: SystemPlugin] reflection — no type from
    them is used statically. A published (trimmed/AOT) build would otherwise remove these whole
    assemblies, so SystemPluginDiscovery finds nothing and the per-system menu/UI never appears.
    Root them so the trimmer keeps them intact.
    Unlike the shell ProjectReference glob above, TrimmerRootAssembly takes assembly *names* (not
    paths) and cannot be globbed — adding a new system still requires adding its
    App.WASM.Shell.<System> and Impl.AspNet.<System> here. (Known open item.)
  -->
  <ItemGroup>
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.App.WASM.Shell.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Impl.AspNet.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Systems.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.App.WASM.Shell.Generic" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Impl.AspNet.Generic" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Systems.Generic" />
  </ItemGroup>

  <!--
    Plug-in discovery manifest (browser WASM).
    SystemPluginDiscovery loads plug-in assemblies by (a) a transitive reference walk from the
    entry assembly and (b) a scan of the output directory. Browser WASM has no enumerable
    filesystem, so (b) finds nothing; and a system-agnostic host holds no static reference to the
    per-system plug-in assemblies for (a) to follow — so neither works here.
    This target emits, into the entry assembly, one
    [assembly: AssemblyMetadata("Highbyte.DotNet6502.PluginAssembly", "<name>")] per
    Highbyte.DotNet6502.* assembly in the resolved reference closure (direct + transitive).
    SystemPluginDiscovery reads that manifest and Assembly.Loads each by name. Convention-based:
    adding a new system needs no edit here. (The TrimmerRootAssembly block above is the
    complementary half — it keeps those assemblies in the bundle so Assembly.Load can find them.)
  -->
  <Target Name="EmitPluginAssemblyManifest"
          DependsOnTargets="ResolveReferences"
          BeforeTargets="GetAssemblyAttributes">
    <ItemGroup>
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferencePath.FileName)"
                        Condition="$([System.String]::Copy('%(ReferencePath.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferenceDependencyPaths.FileName)"
                        Condition="$([System.String]::Copy('%(ReferenceDependencyPaths.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <PackageReference Include="Blazored.LocalStorage" />
    <PackageReference Include="Blazored.Modal" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" PrivateAssets="all" />
    <PackageReference Include="Microsoft.AspNetCore.WebUtilities" />
    <PackageReference Include="SkiaSharp.Views.Blazor" />
    <PackageReference Include="PublishSPAforGitHubPages.Build" />
    <PackageReference Include="TextCopy" />
    <PackageReference Include="Toolbelt.Blazor.Gamepad" />
  </ItemGroup>
  
  <ItemGroup>
    <Folder Include="wwwroot\images\" />
  </ItemGroup>

  <Target Name="CopyC64ExampleBinaries" AfterTargets="AfterBuild">
    <Copy SourceFiles="..\..\..\..\samples\Assembler\C64\Raster\Build\smooth_scroller_and_raster.prg" DestinationFolder="wwwroot\6502binaries\C64\Assembler" />
    <Copy SourceFiles="..\..\..\..\samples\Assembler\C64\Raster\Build\scroller_and_raster.prg" DestinationFolder="wwwroot\6502binaries\C64\Assembler" />

    <Copy SourceFiles="..\..\..\..\samples\Basic\C64\Text\Build\HelloWorld.prg" DestinationFolder="wwwroot\6502binaries\C64\Basic" />
    <Copy SourceFiles="..\..\..\..\samples\Basic\C64\Sound\Build\PlaySoundVoice1TriangleScale.prg" DestinationFolder="wwwroot\6502binaries\C64\Basic" />
  </Target>

  <Target Name="CopyGenericExampleBinaries" AfterTargets="AfterBuild">
    <Copy SourceFiles="..\..\..\..\samples\Assembler\Generic\Build\hostinteraction_scroll_text_and_cycle_colors.prg" DestinationFolder="wwwroot\6502binaries\Generic\Assembler" />
    <Copy SourceFiles="..\..\..\..\samples\Assembler\Generic\Build\snake6502.prg" DestinationFolder="wwwroot\6502binaries\Generic\Assembler" />
  </Target>

  <Target Name="CopyImages" AfterTargets="AfterBuild">
    <Copy SourceFiles="..\..\..\..\resources\images\logo-simple-text.png" DestinationFiles="wwwroot\images\logo.png" />
    <Copy SourceFiles="..\..\..\..\resources\images\favicon.ico" DestinationFolder="wwwroot" />
  </Target>
  
</Project>
