<Project Sdk="Microsoft.NET.Sdk.WebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0-browser</TargetFramework>
    <OutputType>Exe</OutputType>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <DefineConstants>$(DefineConstants);BROWSER</DefineConstants>
    
    <!-- Fix for inclusion of SkiaSharp native assets -->
    <WasmBuildNative>true</WasmBuildNative>

    <!-- WASM SIMD optimization - improves performance -->
    <WasmEnableSIMD>true</WasmEnableSIMD>

    <!-- AOT compilation is not supported for Avalonia Browser WASM with SkiaSharp -->
    <RunAOTCompilation>true</RunAOTCompilation>
    
    <!-- Add additional LLVM optimization -->
    <WasmEnableLLVM>true</WasmEnableLLVM>

    <!-- Use interpreter for startup, JIT for hot paths. Used if AOT isn't enabled, like in Debug mode -->
    <WasmEnableJiterpreter>true</WasmEnableJiterpreter>

    <!-- Optionally disable aggressive trimming to prevent runtime hangs -->
    <!--<PublishTrimmed>false</PublishTrimmed>-->

    <!-- Emscripten linker optimization - O1 for safety, O2/O3 for more speed -->
    <EmccLinkOptimizationFlag>-O3</EmccLinkOptimizationFlag>
    
    <!-- Reduce ICU data size for faster loading (unless you need full internationalization) -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <WasmIncludeFullIcuData>false</WasmIncludeFullIcuData>

    
    <!-- DEBUGGING FIX: Disable problematic debug features for VS2022 -->
    <!--<WasmEnableWebcil>false</WasmEnableWebcil>
    <WasmDebugLevel>0</WasmDebugLevel>-->

  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Browser" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <!-- <PackageReference Include="SkiaSharp" />
    <PackageReference Include="SkiaSharp.NativeAssets.WebAssembly" /> -->
  </ItemGroup>

  <!--
    Preserve the entire ReactiveUI assembly from IL trimming. The WASM trimmer otherwise
    strips types like RxSchedulers and RxAppBuilder that our code references (the Core
    project uses RxSchedulers.MainThreadScheduler across many ViewModels), producing
    TypeLoadException at AOT load time.
  -->
  <ItemGroup>
    <TrimmerRootAssembly Include="ReactiveUI" />
    <!--
      Preserve MoonSharp and our scripting wrapper in AOT/browser publishes.
      Published WASM builds have shown missing Lua standard library functions
      (for example ipairs/table.insert becoming nil), which strongly suggests
      trimming is removing reflection-driven MoonSharp runtime pieces.
    -->
    <TrimmerRootAssembly Include="MoonSharp.Interpreter" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Scripting.MoonSharp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.App.Avalonia.Core\Highbyte.DotNet6502.App.Avalonia.Core.csproj" />
    <!-- Convention glob: every per-system shell is deployed for SystemPluginDiscovery without
         editing this entry exe when a new system is added. -->
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\Highbyte.DotNet6502.App.Avalonia.Shell.*\*.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.Browser\Highbyte.DotNet6502.Impl.Browser.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Scripting.MoonSharp\Highbyte.DotNet6502.Scripting.MoonSharp.csproj" />
  </ItemGroup>

  <!--
    Keep the per-system plug-in assemblies in the trimmed/AOT bundle. They are loaded only by
    reflection (SystemPluginDiscovery), so without rooting the trimmer would drop them entirely
    and Assembly.Load (driven by the manifest below) would then fail.
    NOTE: still per-system — adding a system needs new entries here. (Tracked open item.)
  -->
  <ItemGroup>
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.App.Avalonia.Shell.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Impl.Avalonia.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Systems.Commodore64" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.App.Avalonia.Shell.Generic" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Impl.Avalonia.Generic" />
    <TrimmerRootAssembly Include="Highbyte.DotNet6502.Systems.Generic" />
  </ItemGroup>

  <!--
    Plug-in discovery manifest (browser WASM).
    SystemPluginDiscovery loads plug-in assemblies by (a) a transitive reference walk from the
    entry assembly and (b) a scan of the output directory. Browser WASM has no enumerable
    filesystem, so (b) finds nothing; and a system-agnostic host holds no static reference to the
    per-system plug-in assemblies for (a) to follow — so neither works here.
    This target emits, into the entry assembly, one
    [assembly: AssemblyMetadata("Highbyte.DotNet6502.PluginAssembly", "<name>")] per
    Highbyte.DotNet6502.* assembly in the resolved reference closure (direct + transitive).
    SystemPluginDiscovery reads that manifest and Assembly.Loads each by name. Convention-based:
    adding a new system needs no edit here. (The TrimmerRootAssembly block above is the
    complementary half — it keeps those assemblies in the bundle so Assembly.Load can find them.)
  -->
  <Target Name="EmitPluginAssemblyManifest"
          DependsOnTargets="ResolveReferences"
          BeforeTargets="GetAssemblyAttributes">
    <ItemGroup>
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferencePath.FileName)"
                        Condition="$([System.String]::Copy('%(ReferencePath.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferenceDependencyPaths.FileName)"
                        Condition="$([System.String]::Copy('%(ReferenceDependencyPaths.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
    </ItemGroup>
  </Target>

  <!-- Embedded JavaScript resources for browser interop -->
  <ItemGroup>
    <EmbeddedResource Include="BrowserScripting.js" />
  </ItemGroup>

  <!-- Copy Lua example scripts from central resources location to wwwroot so they are served at runtime -->
  <Target Name="CopyExampleScripts" AfterTargets="AfterBuild">
    <ItemGroup>
      <_SharedScripts Include="$(MSBuildThisFileDirectory)..\..\..\..\resources\scripts\shared\*" />
    </ItemGroup>
    <Copy SourceFiles="@(_SharedScripts)" DestinationFolder="wwwroot\scripts" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopySharedAssets" AfterTargets="AfterBuild">
    <!-- Copy logo image from central resources folder -->
    <Copy SourceFiles="..\..\..\..\resources\images\logo-simple-text-solid-bg.png" DestinationFiles="wwwroot\images\logo.png" />
    <!-- Copy favicon from central resources folder -->
    <Copy SourceFiles="..\..\..\..\resources\images\favicon.ico" DestinationFolder="wwwroot" />
  </Target>

  <Target Name="ReplaceVersionPlaceholders" AfterTargets="Publish">
    <!-- Replace version placeholders in published files -->
    <ItemGroup>
      <FilesToUpdate Include="$(PublishUrl)wwwroot\**\*.html" />
      <FilesToUpdate Include="$(PublishUrl)wwwroot\**\*.js" />
    </ItemGroup>
    <Message Text="Replacing version placeholders in published files..." />
    <!-- This will be handled by the GitHub Actions workflow -->
  </Target>

</Project>
