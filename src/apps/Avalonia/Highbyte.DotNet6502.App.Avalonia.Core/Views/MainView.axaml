<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Highbyte.DotNet6502.App.Avalonia.Core.ViewModels"
    xmlns:controls="using:Highbyte.DotNet6502.App.Avalonia.Core.Controls"
    xmlns:views="using:Highbyte.DotNet6502.App.Avalonia.Core.Views"
    x:Class="Highbyte.DotNet6502.App.Avalonia.Core.Views.MainView"
    x:DataType="vm:MainViewModel"
    Loaded="MainView_Loaded"
    Focusable="false"
    Opacity="0"
    Background="{DynamicResource ViewDefaultBg}">

    <!-- DataContext will be set from code-behind via DI -->

    <UserControl.Styles>
        <!-- Include non-focusable styles -->
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/NonFocusableStyles.axaml"/>
        <Style Selector="Button.sort-header">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.sort-header:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </UserControl.Styles>

    <Grid ShowGridLines="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition MaxWidth="200" />
        </Grid.ColumnDefinitions>

        <!-- Menu and Controls Panel (Left) -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Classes="panel-container">
            <StackPanel Classes="spacing-none">
                <!-- System Selection, Variant, and Status - Unified Grid -->
                <Grid Classes="spacing-none">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="Labels" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- System Selection -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                        Text="System:"
                        Classes="accent bold"
                        VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                        Name="SystemSelectionComboBox"
                        AutomationProperties.AutomationId="SystemSelectionComboBox"
                        AutomationProperties.Name="System selection"
                        ItemsSource="{Binding AvailableSystems}"
                        SelectedItem="{Binding SelectedSystemName}"
                        SelectionChanged="OnSystemSelectionChanged"
                        IsEnabled="{Binding IsEmulatorUninitialized}"
                        Classes="small"
                        MinWidth="100"/>

                    <!-- System Variant Selection -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                        Text="Variant:"
                        Classes="accent bold"
                        VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                        Name="SystemVariantSelectionComboBox"
                        AutomationProperties.AutomationId="SystemVariantSelectionComboBox"
                        AutomationProperties.Name="System variant selection"
                        ItemsSource="{Binding AvailableSystemVariants}"
                        SelectedItem="{Binding SelectedSystemVariant}"
                        SelectionChanged="OnSystemVariantSelectionChanged"
                        IsEnabled="{Binding IsEmulatorUninitialized}"
                        Classes="small"
                        MinWidth="100"/>

                    <!-- Status -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                        Text="Status:"
                        Classes="accent bold"
                        VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                        AutomationProperties.AutomationId="EmulatorStateText"
                        Text="{Binding EmulatorState}"/>
                </Grid>

                <!-- Control Buttons -->
                <StackPanel Classes="spacing-tight">
                    <!-- First row: Start and Pause -->
                    <Grid Classes="spacing-tight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                            Content="Start"
                            AutomationProperties.AutomationId="StartButton"
                            Classes="primary grid"
                            Command="{Binding StartCommand}"/>
                        <Button Grid.Column="2"
                            Content="Pause"
                            AutomationProperties.AutomationId="PauseButton"
                            Classes="warning grid"
                            Command="{Binding PauseCommand}"/>
                    </Grid>

                    <!-- Second row: Reset and Stop -->
                    <Grid Classes="spacing-tight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                            Content="Reset"
                            AutomationProperties.AutomationId="ResetButton"
                            Classes="secondary grid"
                            Command="{Binding ResetCommand}"/>
                        <Button Grid.Column="2"
                            Content="Stop"
                            AutomationProperties.AutomationId="StopButton"
                            Classes="danger grid"
                            Command="{Binding StopCommand}"/>
                    </Grid>

                    <!-- Third row: Monitor and Stats -->
                    <Grid Classes="spacing-tight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                            Content="Monitor"
                            AutomationProperties.AutomationId="MonitorButton"
                            Classes="grid"
                            Command="{Binding MonitorCommand}"
                            ToolTip.Tip="Toggle with F12"/>
                        <Button Grid.Column="2"
                            Content="Stats"
                            AutomationProperties.AutomationId="StatsButton"
                            Classes="grid"
                            Command="{Binding StatsCommand}"
                            ToolTip.Tip="Toggle with F11"/>
                    </Grid>
                </StackPanel>
    
                <!-- Common display and audio settings -->
                <StackPanel Classes="spacing-tight">
                    <!-- Display Settings -->
                    <Grid Classes="spacing-tight">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                            Text="Scale:"
                            Classes="accent bold"/>
                        <Slider Grid.Column="1"
                            AutomationProperties.AutomationId="ScaleSlider"
                            AutomationProperties.Name="Scale"
                            Minimum="1" Maximum="4"
                            Value="{Binding Scale}"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            Classes="small"/>
                    </Grid>

                    <!-- Audio Settings -->
                    <StackPanel Classes="spacing-tight" >
                        <Grid Classes="spacing-tight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                Content="Audio"
                                AutomationProperties.AutomationId="AudioCheckBox"
                                IsVisible="true"
                                IsEnabled="{Binding AudioSettingsEnabled }"
                                IsChecked="{Binding AudioEnabled}"
                                ToolTip.Tip="{Binding AudioTooltip}"/>
                            <Slider Grid.Column="1"
                                AutomationProperties.AutomationId="AudioVolumeSlider"
                                AutomationProperties.Name="Audio volume"
                                Width="100"
                                Minimum="0" Maximum="100"
                                Value="{Binding AudioVolumePercent}"
                                TickFrequency="5"
                                IsSnapToTickEnabled="False"
                                IsEnabled="{Binding AudioEnabled }"
                                Classes="small"/>
                        </Grid>
                    </StackPanel>

                    <!-- Other general functions -->
                    <StackPanel Classes="spacing-tight" >
                        <Grid Classes="spacing-tight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- General Emulator Options Button -->
                            <Button Grid.Column="0"
                                    Content="Options"
                                    AutomationProperties.AutomationId="OptionsButton"
                                    Command="{Binding EmulatorOptionsCommand}"
                                    Classes="grid small"
                                    ToolTip.Tip="Configure general emulator settings"/>

                       </Grid>
                    </StackPanel>

                </StackPanel>

                <!-- Separator -->
                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,8,0,8" />

                <!-- C64 Menu -->
                <views:C64MenuView DataContext="{Binding C64MenuViewModel}" IsVisible="{Binding $parent[UserControl].DataContext.IsC64SystemSelected}" />

            </StackPanel>
        </Border>

        <!-- Main Emulator Display Area (Center) -->
        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
            Name="CenterPanel"
            Background="{DynamicResource ViewDefaultBg}"
            Classes="panel-container">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                    Name="EmulatorDisplayGrid"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    
                    <!-- Emulator Display Control -->
                    <views:EmulatorView Name="EmulatorView"
                        DataContext="{Binding EmulatorViewModel}"
                        Scale="{Binding $parent[UserControl].DataContext.Scale}"
                        IsVisible="{Binding !$parent[UserControl].DataContext.IsEmulatorUninitialized}"/>                        

                <!-- Overlay message when not running -->
                   <views:EmulatorPlaceholderView Name="EmulatorPlaceholderView"
                        DataContext="{Binding EmulatorPlaceholderViewModel}"
                        Scale="{Binding $parent[UserControl].DataContext.Scale}"
                        IsVisible="{Binding $parent[UserControl].DataContext.IsEmulatorUninitialized}"/>
                </Grid>

                <!-- Information Area - Tabbed Interface -->
                <Border Grid.Row="1"
                    Classes="panel-container v-top h-left"
                    Height="230"
                    Width="{Binding #EmulatorDisplayGrid.Bounds.Width}">
                    
                    <TabControl Name="InformationTabControl"
                                AutomationProperties.AutomationId="InformationTabControl">
                        <!-- Information Tab -->
                        <TabItem Name="InformationTabItem" Header="Information"
                                 AutomationProperties.AutomationId="InformationTab"
                                 AutomationProperties.Name="Information tab">
                            <Border Classes="tab-content">
                                <ScrollViewer Classes="auto-scroll">
                                    <!-- C64 Info panel-->
                                    <views:C64InfoView DataContext="{Binding C64InfoViewModel}" IsVisible="{Binding $parent[UserControl].DataContext.IsC64SystemSelected}" />
                                </ScrollViewer>
                            </Border>
                        </TabItem>

                        <!-- Config Status Tab -->
                        <TabItem Name="ConfigStatusTabItem" Header="Config status"
                                 AutomationProperties.AutomationId="ConfigStatusTab"
                                 AutomationProperties.Name="Config status tab">
                            <Border Classes="tab-content">
                                <ScrollViewer Classes="auto-scroll">
                                    <StackPanel Classes="spacing-tight">
                                        <StackPanel Classes="spacing-tight" IsVisible="{Binding HasValidationErrors}">
                                            <Border Classes="error-container">
                                                <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                                <TextBlock Text="•"
                                                                    Classes="error"/>
                                                                <TextBlock Text="{Binding}"
                                                                    Classes="small"
                                                                    TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Classes="spacing-tight" IsVisible="{Binding !HasValidationErrors}">
                                            <TextBlock Text="Configuration is valid."
                                                Classes="small secondary-text"
                                                FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>

                        <!-- Log Tab -->
                        <TabItem Name="LogTabItem" Header="{Binding LogTabHeader}"
                                 AutomationProperties.AutomationId="LogTab"
                                 AutomationProperties.Name="Log tab"
                                 Classes.error-log="{Binding HasLogErrors}">
                            <Border Classes="tab-content">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Log content -->
                                    <ScrollViewer Grid.Column="0" x:Name="LogScrollViewer" Classes="auto-scroll">
                                    <ItemsControl ItemsSource="{Binding LogMessages}" Classes="vertical-tight" Padding="0,0,0,14">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.Styles>
                                            <!-- Log level color styles -->
                                            <Style Selector="TextBlock.log-symbol">
                                                <Setter Property="FontSize" Value="10"/>
                                                <Setter Property="Height" Value="10"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-trace">
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-debug">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-info">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-warning">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningColor}"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-error">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                            </Style>
                                            <Style Selector="TextBlock.log-critical">
                                                <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                            </Style>
                                            <!-- Log message styles -->
                                            <Style Selector="TextBlock.log-message">
                                                <Setter Property="FontFamily" Value="Consolas,Monaco,'Courier New',monospace"/>
                                                <Setter Property="FontSize" Value="10"/>
                                                <Setter Property="Height" Value="10"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                            </Style>
                                            <Style Selector="SelectableTextBlock.log-message">
                                                <Setter Property="Padding" Value="4,1"/>
                                                <Setter Property="FontFamily" Value="Consolas,Monaco,'Courier New',monospace"/>
                                                <Setter Property="FontSize" Value="10"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="VerticalAlignment" Value="Top"/>
                                            </Style>
                                        </ItemsControl.Styles>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="16" />  <!-- Fixed width for symbol alignment -->
                                                        <ColumnDefinition Width="Auto" />   <!-- Auto width for message to allow horizontal scrolling -->
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Copy message"
                                                                      Click="LogEntryContextMenu_CopyMessage_Click"
                                                                      AutomationProperties.AutomationId="LogCopyMessageMenuItem"/>
                                                        </ContextMenu>
                                                    </Grid.ContextMenu>

                                                    <!-- Symbol container with proper alignment -->
                                                    <TextBlock Grid.Column="0"
                                                        Text="{Binding Symbol}"
                                                        Classes="log-symbol"
                                                        Classes.log-trace="{Binding IsTrace}"
                                                        Classes.log-debug="{Binding IsDebug}"
                                                        Classes.log-info="{Binding IsInfo}"
                                                        Classes.log-warning="{Binding IsWarning}"
                                                        Classes.log-error="{Binding IsError}"
                                                        Classes.log-critical="{Binding IsCritical}"/>

                                                    <!-- Message text (selectable for Cmd+C / Ctrl+C) -->
                                                    <SelectableTextBlock Grid.Column="1"
                                                        Text="{Binding Message}"
                                                        Classes="log-message"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Log action buttons column -->
                                <Border Grid.Column="1" Classes="v-top" Margin="4,0,0,0">
                                    <StackPanel Spacing="4">
                                        <Button Click="CopyAllLog_Click"
                                                AutomationProperties.AutomationId="CopyAllLogButton"
                                                AutomationProperties.Name="Copy all log"
                                                Classes="small"
                                                Width="60"
                                                Height="20"
                                                FontSize="10"
                                                ToolTip.Tip="Copy all log messages to clipboard">
                                            Copy all
                                        </Button>
                                        <Button Command="{Binding ClearLogCommand}"
                                                AutomationProperties.AutomationId="ClearLogButton"
                                                Classes="small"
                                                Width="60"
                                                Height="20"
                                                FontSize="10"
                                                ToolTip.Tip="Clear log messages">
                                            Clear
                                        </Button>
                                    </StackPanel>
                                </Border>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- Scripts Tab -->
                        <TabItem Name="ScriptsTabItem"
                                 AutomationProperties.AutomationId="ScriptsTab"
                                 AutomationProperties.Name="Scripts tab"
                                 Header="{Binding ScriptsTabHeader}"
                                 Classes.disabled-scripts="{Binding HasDisabledScripts}">
                            <Border Classes="tab-content">
                                <ScrollViewer Classes="auto-scroll">
                                    <StackPanel Classes="spacing-tight">
                                        <!-- Scripting disabled status (only shown when scripting is off) -->
                                        <StackPanel Orientation="Horizontal" Classes="spacing-tight"
                                                    IsVisible="{Binding !IsScriptingEnabled}">
                                            <TextBlock Text="Scripting:"
                                                       Classes="small bold"/>
                                            <TextBlock Text="Disabled"
                                                       Classes="small"
                                                       Foreground="{DynamicResource SecondaryText}"/>
                                        </StackPanel>

                                        <!-- Script table -->
                                        <StackPanel IsVisible="{Binding IsScriptingEnabled}">

                                            <!-- Desktop info banner (shown when not in manage/browser mode) -->
                                            <Border IsVisible="{Binding ShowScriptDirectoryInfo}"
                                                    Background="{DynamicResource SecondaryBg}"
                                                    BorderBrush="{DynamicResource BorderColor}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,6"
                                                    Margin="0,0,0,6">
                                                <StackPanel Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <Button Content="↻"
                                                                AutomationProperties.AutomationId="ScriptsBannerRefreshButton"
                                                                AutomationProperties.Name="Reload scripts from folder"
                                                                Command="{Binding RefreshScriptsCommand}"
                                                                FontSize="12"
                                                                Height="22" Padding="4,0"
                                                                MinWidth="0" MinHeight="0"
                                                                VerticalAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                ToolTip.Tip="Reload scripts from folder"/>
                                                        <TextBlock Text="Script folder:"
                                                                   Classes="small bold"
                                                                   VerticalAlignment="Center"/>
                                                        <Button Content="{Binding ScriptDirectory}"
                                                                AutomationProperties.AutomationId="ScriptFolderLink"
                                                                AutomationProperties.Name="Open script folder in file browser"
                                                                Command="{Binding OpenScriptFolderCommand}"
                                                                Classes="link"
                                                                FontSize="10"
                                                                Padding="0"
                                                                Margin="0"
                                                                BorderThickness="0"
                                                                VerticalAlignment="Center"
                                                                ToolTip.Tip="Open script folder in file browser"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Use your OS file browser and editor to add, edit, or delete scripts. The script directory is set in appsettings.json in the same folder as the emulator executable. Restart app after making changes to the script directory path."
                                                               Classes="small"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Add script + Load Examples + Refresh buttons (browser/manage mode only) -->
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6"
                                                        Margin="0,0,0,4"
                                                        IsVisible="{Binding CanManageScripts}">
                                                <Button Content="+ Add Script"
                                                        AutomationProperties.AutomationId="AddScriptButton"
                                                        Command="{Binding AddScriptCommand}"
                                                        FontSize="10"
                                                        Padding="6,2"
                                                        MinWidth="0"
                                                        MinHeight="0"/>
                                                <Button Content="Load Examples"
                                                        AutomationProperties.AutomationId="LoadExamplesButton"
                                                        Command="{Binding LoadExamplesCommand}"
                                                        IsVisible="{Binding CanLoadExamples}"
                                                        FontSize="10"
                                                        Padding="6,2"
                                                        MinWidth="0"
                                                        MinHeight="0"/>
                                                <Button Content="↻"
                                                        AutomationProperties.AutomationId="ScriptsRefreshButton"
                                                        AutomationProperties.Name="Reload all scripts from localStorage"
                                                        Command="{Binding RefreshScriptsCommand}"
                                                        FontSize="12"
                                                        Height="22" Padding="4,0"
                                                        MinWidth="0" MinHeight="0"
                                                        VerticalAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        ToolTip.Tip="Reload all scripts from localStorage"/>
                                            </StackPanel>

                                            <!-- Header row -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="5" Classes="sort-header"
                                                        AutomationProperties.AutomationId="SortByFileNameButton"
                                                        AutomationProperties.Name="Sort by script file name"
                                                        Command="{Binding SortByColumnCommand}"
                                                        CommandParameter="{x:Static vm:ScriptSortColumn.FileName}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Script" Classes="small bold" FontSize="10"/>
                                                        <TextBlock Text="{Binding FileNameSortIndicator}" Classes="small bold" FontSize="10"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="6" Classes="sort-header"
                                                        AutomationProperties.AutomationId="SortByStatusButton"
                                                        AutomationProperties.Name="Sort by script status"
                                                        Command="{Binding SortByColumnCommand}"
                                                        CommandParameter="{x:Static vm:ScriptSortColumn.Status}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Status" Classes="small bold" FontSize="10"/>
                                                        <TextBlock Text="{Binding StatusSortIndicator}" Classes="small bold" FontSize="10"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="7" Classes="sort-header"
                                                        AutomationProperties.AutomationId="SortByYieldButton"
                                                        AutomationProperties.Name="Sort by yield type"
                                                        Command="{Binding SortByColumnCommand}"
                                                        CommandParameter="{x:Static vm:ScriptSortColumn.YieldType}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Yield" Classes="small bold" FontSize="10"/>
                                                        <TextBlock Text="{Binding YieldSortIndicator}" Classes="small bold" FontSize="10"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="8" Classes="sort-header"
                                                        AutomationProperties.AutomationId="SortByHooksButton"
                                                        AutomationProperties.Name="Sort by hooks"
                                                        Command="{Binding SortByColumnCommand}"
                                                        CommandParameter="{x:Static vm:ScriptSortColumn.Hooks}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Hooks" Classes="small bold" FontSize="10"/>
                                                        <TextBlock Text="{Binding HooksSortIndicator}" Classes="small bold" FontSize="10"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Separator -->
                                            <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,0,0,1"/>

                                            <!-- Data rows -->
                                            <ItemsControl ItemsSource="{Binding ScriptEntries}">
                                                <ItemsControl.Styles>
                                                    <Style Selector="TextBlock.script-status-dot">
                                                        <Setter Property="FontSize" Value="8"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessColor}"/>
                                                    </Style>
                                                    <Style Selector="TextBlock.script-disabled">
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerColor}"/>
                                                    </Style>
                                                    <Style Selector="TextBlock.script-completed">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                                    </Style>
                                                    <Style Selector="TextBlock.script-user-disabled">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
                                                    </Style>
                                                </ItemsControl.Styles>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="200"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Status indicator dot -->
                                                            <TextBlock Grid.Column="0"
                                                                       Text="●"
                                                                       Classes="script-status-dot"
                                                                       Classes.script-disabled="{Binding IsDisabled}"
                                                                       Classes.script-completed="{Binding IsCompleted}"
                                                                       Classes.script-user-disabled="{Binding IsUserDisabled}"/>

                                                            <!-- Enable/disable toggle -->
                                                            <Viewbox Grid.Column="1"
                                                                     Width="18" Height="22"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Stretch="Uniform"
                                                                     Margin="0,1,0,-1">
                                                                <CheckBox IsChecked="{Binding IsScriptEnabled, Mode=OneWay}"
                                                                          IsEnabled="{Binding CanToggle}"
                                                                          AutomationProperties.AutomationId="{Binding FileName, StringFormat='ScriptRow.ToggleEnabled.{0}'}"
                                                                          AutomationProperties.Name="Enable or disable script"
                                                                          Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ToggleScriptEnabledCommand}"
                                                                          CommandParameter="{Binding FileName}"
                                                                          Padding="0"
                                                                          MinWidth="0"
                                                                          MinHeight="0"/>
                                                            </Viewbox>

                                                            <!-- Reload button -->
                                                            <Button Grid.Column="2"
                                                                    Content="↻"
                                                                    AutomationProperties.AutomationId="{Binding FileName, StringFormat='ScriptRow.Reload.{0}'}"
                                                                    AutomationProperties.Name="Reload script"
                                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ReloadScriptCommand}"
                                                                    CommandParameter="{Binding FileName}"
                                                                    IsEnabled="{Binding CanReload}"
                                                                    FontSize="12"
                                                                    Height="22"
                                                                    Padding="4,0"
                                                                    MinWidth="0"
                                                                    MinHeight="0"
                                                                    VerticalAlignment="Center"
                                                                    VerticalContentAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    ToolTip.Tip="Reload script"/>

                                                            <!-- Edit button (browser/manage mode only) -->
                                                            <Button Grid.Column="3"
                                                                    AutomationProperties.AutomationId="{Binding FileName, StringFormat='ScriptRow.Edit.{0}'}"
                                                                    AutomationProperties.Name="Edit script"
                                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).EditScriptCommand}"
                                                                    CommandParameter="{Binding FileName}"
                                                                    IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).CanManageScripts}"
                                                                    Height="22"
                                                                    Padding="4,0"
                                                                    MinWidth="0"
                                                                    MinHeight="0"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    ToolTip.Tip="Edit script">
                                                                <PathIcon Width="12" Height="12"
                                                                          Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"/>
                                                            </Button>

                                                            <!-- Delete button (browser/manage mode only) -->
                                                            <Button Grid.Column="4"
                                                                    AutomationProperties.AutomationId="{Binding FileName, StringFormat='ScriptRow.Delete.{0}'}"
                                                                    AutomationProperties.Name="Delete script"
                                                                    Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).DeleteScriptCommand}"
                                                                    CommandParameter="{Binding FileName}"
                                                                    IsVisible="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).CanManageScripts}"
                                                                    Height="22"
                                                                    Padding="4,0"
                                                                    MinWidth="0"
                                                                    MinHeight="0"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    ToolTip.Tip="Delete script">
                                                                <PathIcon Width="12" Height="12"
                                                                          Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                                                            </Button>

                                                            <!-- File name -->
                                                            <TextBlock Grid.Column="5"
                                                                       Text="{Binding FileName}"
                                                                       Classes="small"
                                                                       FontFamily="Consolas,Monaco,'Courier New',monospace"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <!-- Status -->
                                                            <TextBlock Grid.Column="6"
                                                                       Text="{Binding Status}"
                                                                       Classes="small"
                                                                       FontSize="10"
                                                                       VerticalAlignment="Center"
                                                                       Classes.script-disabled="{Binding IsDisabled}"
                                                                       Classes.script-user-disabled="{Binding IsUserDisabled}"/>

                                                            <!-- Yield Type -->
                                                            <TextBlock Grid.Column="7"
                                                                       Text="{Binding YieldType}"
                                                                       Classes="small"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryText}"
                                                                       VerticalAlignment="Center"/>

                                                            <!-- Hooks -->
                                                            <TextBlock Grid.Column="8"
                                                                       Text="{Binding Hooks}"
                                                                       Classes="small"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryText}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Empty state -->
                                        <TextBlock Text="No scripts loaded."
                                                   Classes="small secondary-text"
                                                   FontStyle="Italic"
                                                   IsVisible="{Binding !ScriptEntries.Count}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>

                        <!-- Debug  -->
                        <TabItem Name="DebugAndRemotingTabItem" Header="Debug &amp; Remoting"
                                 IsVisible="{Binding IsDebugTabVisible}"
                                 AutomationProperties.AutomationId="DebugAndRemotingTab"
                                 AutomationProperties.Name="Debug &amp; Remoting tab">
                            <Border Classes="tab-content">
                                <ScrollViewer Classes="auto-scroll">
                                    <StackPanel Classes="spacing-tight">

                                        <!-- External Debug Server (Desktop only; hidden on Browser via IsExternalDebugServerAvailable) -->
                                        <StackPanel Classes="spacing-tight"
                                                    IsVisible="{Binding IsExternalDebugServerAvailable}">
                                            <TextBlock Text="VSCode Debug Server"
                                                       Classes="accent bold"
                                                       FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Classes="spacing-normal">
                                                <!-- Start/Stop toggle button -->
                                                <Button Content="{Binding ExternalDebugToggleButtonText}"
                                                        AutomationProperties.AutomationId="ExternalDebugToggleButton"
                                                        AutomationProperties.Name="Start or stop the TCP debug adapter server"
                                                        Command="{Binding ToggleExternalDebugCommand}"
                                                        Classes="small"
                                                        MinWidth="46"
                                                        Height="20"
                                                        FontSize="10"
                                                        ToolTip.Tip="Start or stop the TCP debug adapter server"/>
                                                <!-- Bind address label + text box -->
                                                <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                    <TextBlock Text="Bind:"
                                                               Classes="accent bold"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding ExternalDebugBindAddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             AutomationProperties.AutomationId="ExternalDebugBindAddressInput"
                                                             AutomationProperties.Name="External debug server bind IP address"
                                                             IsEnabled="{Binding !IsExternalDebugListening}"
                                                             Width="90"
                                                             Classes="small"
                                                             TextInput="OnIpv4TextInput"
                                                             TextChanged="OnIpv4TextChanged"
                                                             ToolTip.Tip="{Binding ExternalDebugBindAddressInputToolTip}"/>
                                                </StackPanel>
                                                <!-- Port label + number (no spinners, fixed width) -->
                                                <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                    <TextBlock Text="Port:"
                                                               Classes="accent bold"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding ExternalDebugPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             AutomationProperties.AutomationId="ExternalDebugPortInput"
                                                             AutomationProperties.Name="External debug server TCP port"
                                                             IsEnabled="{Binding !IsExternalDebugListening}"
                                                             Width="68"
                                                             MaxLength="5"
                                                             Classes="small"
                                                             TextInput="OnDigitsOnlyTextInput"
                                                             TextChanged="OnPortTextChanged"
                                                             ToolTip.Tip="{Binding ExternalDebugPortInputToolTip}"/>
                                                </StackPanel>
                                                <!-- Status text -->
                                                <TextBlock Text="{Binding ExternalDebugStatusText}"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Remote Control Server (Desktop only; hidden on Browser via IsRemoteControlAvailable) -->
                                        <StackPanel Classes="spacing-tight"
                                                    IsVisible="{Binding IsRemoteControlAvailable}">
                                            <TextBlock Text="Remote Control Server"
                                                       Classes="accent bold"
                                                       FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Classes="spacing-normal">
                                                <!-- Start/Stop toggle button -->
                                                <Button Content="{Binding RemoteControlToggleButtonText}"
                                                        AutomationProperties.AutomationId="RemoteControlToggleButton"
                                                        AutomationProperties.Name="Start or stop the TCP remote control server"
                                                        Command="{Binding ToggleRemoteControlCommand}"
                                                        Classes="small"
                                                        MinWidth="46"
                                                        Height="20"
                                                        FontSize="10"
                                                        ToolTip.Tip="Start or stop the TCP remote control server"/>
                                                <!-- Bind address label + text box -->
                                                <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                    <TextBlock Text="Bind:"
                                                               Classes="accent bold"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding RemoteControlBindAddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             AutomationProperties.AutomationId="RemoteControlBindAddressInput"
                                                             AutomationProperties.Name="Remote control server bind IP address"
                                                             IsEnabled="{Binding !IsRemoteControlListening}"
                                                             Width="90"
                                                             Classes="small"
                                                             TextInput="OnIpv4TextInput"
                                                             TextChanged="OnIpv4TextChanged"
                                                             ToolTip.Tip="{Binding RemoteControlBindAddressInputToolTip}"/>
                                                </StackPanel>
                                                <!-- Port label + number -->
                                                <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                    <TextBlock Text="Port:"
                                                               Classes="accent bold"
                                                               FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding RemoteControlPortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             AutomationProperties.AutomationId="RemoteControlPortInput"
                                                             AutomationProperties.Name="Remote control server TCP port"
                                                             IsEnabled="{Binding !IsRemoteControlListening}"
                                                             Width="68"
                                                             MaxLength="5"
                                                             Classes="small"
                                                             TextInput="OnDigitsOnlyTextInput"
                                                             TextChanged="OnPortTextChanged"
                                                             ToolTip.Tip="{Binding RemoteControlPortInputToolTip}"/>
                                                </StackPanel>
                                                <!-- Status text -->
                                                <TextBlock Text="{Binding RemoteControlStatusText}"
                                                           AutomationProperties.AutomationId="RemoteControlStatusText"
                                                           AutomationProperties.Name="Remote control server status"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <!-- Fixed-width transient client indicator to avoid layout churn in the tab -->
                                                <Border Width="68"
                                                        Height="18"
                                                        CornerRadius="9"
                                                        Background="#180080FF"
                                                        BorderBrush="#500080FF"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center"
                                                        Opacity="{Binding RemoteClientIndicatorOpacity}"
                                                        IsHitTestVisible="False">
                                                    <Border.Transitions>
                                                        <Transitions>
                                                            <DoubleTransition Property="Opacity" Duration="0:0:0.25"/>
                                                        </Transitions>
                                                    </Border.Transitions>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Spacing="4">
                                                        <Ellipse Width="6"
                                                                 Height="6"
                                                                 Fill="#FF0080FF"
                                                                 VerticalAlignment="Center"/>
                                                        <TextBlock Text="Client"
                                                                   FontSize="9"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#FF0080FF"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Debug tool buttons -->
                                        <StackPanel Classes="spacing-tight" IsVisible="{Binding IsDebugToolsVisible}">

                                            <TextBlock Text="Misc. Debug Tools"
                                                       Classes="accent bold"
                                                       FontSize="11"/>
                                            <StackPanel Orientation="Horizontal" Classes="spacing-normal">

                                                <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                                                    <Button Click="OpenSoundDebug_Click"
                                                            AutomationProperties.AutomationId="DebugSoundButton"
                                                            IsEnabled="{Binding IsEmulatorUninitialized}"
                                                            Classes="small"
                                                            MinWidth="60"
                                                            Height="20"
                                                            FontSize="10">
                                                        Debug sound
                                                    </Button>
                                                    <Button Click="OpenGamepadDebug_Click"
                                                            AutomationProperties.AutomationId="DebugGamepadButton"
                                                            IsEnabled="{Binding IsEmulatorUninitialized}"
                                                            Classes="small"
                                                            MinWidth="60"
                                                            Height="20"
                                                            FontSize="10">
                                                        Debug gamepad
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </TabItem>

                        <!-- General info -->
                        <TabItem Name="GeneralInfoTabItem" Header="General info"
                                 AutomationProperties.AutomationId="GeneralInfoTab"
                                 AutomationProperties.Name="General info tab">
                            <ScrollViewer Classes="auto-scroll">
                                <StackPanel Classes="spacing-tight h-left">

                                    <Border Classes="section-container" Width="500">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="30" MaxWidth="100" />
                                                <ColumnDefinition Width="*" MinWidth="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 1: Version -->
                                            <Border Grid.Row="0" Grid.Column="0" Classes="table-cell">
                                                <TextBlock Text="Version" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="0" Grid.Column="1" Classes="table-cell">
                                                <SelectableTextBlock Text="{Binding Version}" Classes="small" />
                                            </Border>

                                            <!-- Row 2: By -->
                                            <Border Grid.Row="1" Grid.Column="0" Classes="table-cell">
                                                <TextBlock Text="By" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="1" Classes="table-cell">
                                                <SelectableTextBlock Text="Highbyte" Classes="small" />
                                            </Border>

                                            <!-- Row 3: Repo -->
                                            <Border Grid.Row="2" Grid.Column="0" Classes="table-cell">
                                                <TextBlock Text="Repo" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="2" Grid.Column="1" Classes="table-cell">
                                                <SelectableTextBlock Text="https://github.com/highbyte/dotnet-6502" Classes="small" />
                                            </Border>

                                            <!-- Row: OS version -->
                                            <Border Grid.Row="3" Grid.Column="0" Classes="table-cell">
                                                <TextBlock Text="OS" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="3" Grid.Column="1" Classes="table-cell">
                                                <SelectableTextBlock Text="{Binding OSVersion}" Classes="small" />
                                            </Border>

                                            <!-- Row: NET runtime version -->
                                            <Border Grid.Row="4" Grid.Column="0" Classes="table-cell">
                                                <TextBlock Text=".NET" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="4" Grid.Column="1" Classes="table-cell">
                                                <SelectableTextBlock Text="{Binding DotNetVersion}" Classes="small" />
                                            </Border>

                                            <!-- Row: Avalonia version -->
                                            <Border Grid.Row="5" Grid.Column="0" Classes="table-cell-last-row">
                                                <TextBlock Text="Avalonia" Classes="small bold" TextWrapping="Wrap" />
                                            </Border>

                                            <Border Grid.Row="5" Grid.Column="1" Classes="table-cell-last-row">
                                                <SelectableTextBlock Text="{Binding AvaloniaVersion}" Classes="small" />
                                            </Border>

                                        </Grid>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>
                </Border>
            </Grid>
        </Border>

        <!-- Info and Stats Panel (Right) -->
        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Classes="panel-container"
            IsVisible="{Binding IsStatisticsPanelVisible}">
            <ScrollViewer Classes="h-stretch">
                <views:StatisticsView DataContext="{Binding StatisticsViewModel}" />
            </ScrollViewer>
        </Border>

        <!-- Status Bar (Bottom; always present) -->
        <views:StatusBar Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                         HorizontalAlignment="Left"
                         Width="{Binding ElementName=CenterPanel, Path=Bounds.Right}"/>
    </Grid>
</UserControl>
