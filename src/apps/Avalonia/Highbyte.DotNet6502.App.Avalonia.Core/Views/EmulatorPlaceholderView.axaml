<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Highbyte.DotNet6502.App.Avalonia.Core.ViewModels"
             x:Class="Highbyte.DotNet6502.App.Avalonia.Core.Views.EmulatorPlaceholderView"
             x:DataType="vm:EmulatorPlaceholderViewModel"
             AutomationProperties.AutomationId="EmulatorPlaceholderView"
             AutomationProperties.Name="DotNet 6502 Emulator placeholder"
             Focusable="False"
             IsTabStop="False">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center">
        <Image Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/logo.png"
               Width="256"
               Height="256"
               HorizontalAlignment="Center" />
        
        <TextBlock Text="DotNet 6502 Emulator"
                    HorizontalAlignment="Center"
                    Classes="h1" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="0,12,0,0">
            <Button Content="GitHub"
                    AutomationProperties.AutomationId="PlaceholderGitHubLink"
                    AutomationProperties.Name="Open GitHub repository"
                    Classes="text"
                    Padding="0"
                    Margin="0"
                    BorderThickness="0"
                    Click="OpenGitHub_Click"/>
            <Button Content="highbyte.se"
                    AutomationProperties.AutomationId="PlaceholderHomePageLink"
                    AutomationProperties.Name="Open home page"
                    Classes="text"
                    Padding="0"
                    Margin="0"
                    BorderThickness="0"
                    Click="OpenHomePage_Click"/>
        </StackPanel>
    </StackPanel>

    <!--<Grid Background="Black">
        <TextBlock x:Name="MessageTextBlock"
        Text="DotNet 6502 emulator"
        Foreground=""
        FontSize="24"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"/>
    </Grid>-->
    
</UserControl>
