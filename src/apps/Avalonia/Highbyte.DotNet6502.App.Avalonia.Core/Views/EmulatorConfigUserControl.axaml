<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Highbyte.DotNet6502.App.Avalonia.Core.ViewModels"
        x:Class="Highbyte.DotNet6502.App.Avalonia.Core.Views.EmulatorConfigUserControl"
        x:DataType="vm:EmulatorConfigViewModel">
  
  <!-- Simplified layout for overlay dialog.
       MaxWidth caps the dialog so the WrapPanel inside wraps to at most 3 columns of 400 px wide panels. -->
  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="8,0,8,8" MaxWidth="1240">
    <!-- Title Header -->
    <Border Grid.Row="0" CornerRadius="4,4,4,4" Classes="panel-container">
      <TextBlock Text="General Emulator Options"
                 Classes="h-center h2"/>
    </Border>

    <!-- Main content - scrollable -->
    <ScrollViewer Grid.Row="1" Classes="vertical-only">
      <WrapPanel Orientation="Horizontal"> 

        <!-- General Settings Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="General Settings"
                         Classes=""/>
              
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Classes="spacing-tight">
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Default emulator:" 
                           Classes="secondary-text"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          AutomationProperties.AutomationId="DefaultEmulatorComboBox"
                          AutomationProperties.Name="Default emulator"
                          ItemsSource="{Binding AvailableEmulators}"
                          SelectedItem="{Binding SelectedDefaultEmulator}"
                          Width="150"
                          HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="The default system to load when the emulator starts."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      
        <!-- Display Settings Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Display Settings"
                         Classes=""/>
              
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Classes="spacing-tight">
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Default scale:" 
                           Classes="secondary-text"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Classes="spacing-tight">
                  <Slider Minimum="1" Maximum="4"
                          AutomationProperties.AutomationId="DefaultScaleSlider"
                          AutomationProperties.Name="Default scale"
                          Value="{Binding DefaultDrawScale}"
                          TickFrequency="0.5"
                          IsSnapToTickEnabled="True"
                          Width="150"
                          Classes="small"/>
                  <TextBlock Text="{Binding DefaultDrawScale, StringFormat={}{0:F1}x}"
                             Classes="secondary-text"
                             VerticalAlignment="Center"
                             Width="35"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="The default zoom level when the emulator starts."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Error Handling Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Error Handling"
                         Classes=""/>

              <CheckBox Content="Show error dialogs"
                        AutomationProperties.AutomationId="ShowErrorDialogCheckBox"
                        AutomationProperties.Name="Show error dialogs"
                        IsChecked="{Binding ShowErrorDialog}"
                        Classes=""/>
              
              <TextBlock Text="When enabled, errors will be shown in dialog boxes. When disabled, errors are only logged. THE APP NEEDS TO BE RESTARTED FOR IT TO TAKE EFFECT"
                         Classes="small secondary-text"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Developer Options Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Developer Options"
                         Classes=""/>

              <CheckBox Content="Show Debug tools"
                        AutomationProperties.AutomationId="ShowDebugToolsCheckBox"
                        AutomationProperties.Name="Show Debug tools"
                        IsChecked="{Binding ShowDebugTools}"
                        Classes=""/>
              
              <TextBlock Text="When enabled, shows the Debug tools in the Debug and Remoting tab in the main view. Useful for development and debugging purposes."
                         Classes="small secondary-text"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Audio Settings Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Audio Settings"
                         Classes=""/>
              
              <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Classes="spacing-tight">
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Audio profile:" 
                           Classes="secondary-text"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          AutomationProperties.AutomationId="AudioProfileComboBox"
                          AutomationProperties.Name="Audio profile"
                          ItemsSource="{Binding AudioSettingsProfiles}"
                          SelectedItem="{Binding SelectedAudioSettingsProfile}"
                          Width="150"
                          HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Controls the audio latency vs stability tradeoff. Lower latency may cause audio glitches."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Browser sample mode:"
                           Classes="secondary-text"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsRunningInWebAssembly}"
                           Margin="0,8,0,0"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          AutomationProperties.AutomationId="BrowserSampleAudioModeComboBox"
                          AutomationProperties.Name="Browser sample audio mode"
                          ItemsSource="{Binding BrowserSampleAudioModes}"
                          SelectedItem="{Binding SelectedBrowserSampleAudioMode}"
                          Width="180"
                          HorizontalAlignment="Left"
                          IsVisible="{Binding IsRunningInWebAssembly}"
                          Margin="0,8,0,0"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Stable uses the default WebAudio path. DirectWriteAuto uses AudioWorklet when available and falls back otherwise. DirectWriteAudioWorklet requires SharedArrayBuffer."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           IsVisible="{Binding IsRunningInWebAssembly}"
                           Margin="0,4,0,0"/>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Monitor/Debugger Settings Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Monitor/Debugger"
                         Classes=""/>

              <CheckBox Content="Stop on BRK instruction"
                        AutomationProperties.AutomationId="StopOnBrkCheckBox"
                        AutomationProperties.Name="Stop on BRK instruction"
                        IsChecked="{Binding StopAfterBRKInstruction}"
                        Classes=""/>
              
              <TextBlock Text="Automatically pause execution when a BRK instruction is encountered."
                         Classes="small secondary-text"
                         TextWrapping="Wrap"
                         Margin="20,0,0,8"/>

              <CheckBox Content="Stop on unknown instruction"
                        AutomationProperties.AutomationId="StopOnUnknownInstructionCheckBox"
                        AutomationProperties.Name="Stop on unknown instruction"
                        IsChecked="{Binding StopAfterUnknownInstruction}"
                        Classes=""/>
              
              <TextBlock Text="Automatically pause execution when an unknown/illegal opcode is encountered."
                          Classes="small secondary-text"
                          TextWrapping="Wrap"
                          Margin="20,0,0,0"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Lua Scripting Section -->
        <StackPanel Width="400" Classes="wrap-item">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Lua Scripting" Classes=""/>

              <!-- Desktop: Script Directory -->
              <Grid IsVisible="{Binding !IsRunningInWebAssembly}"
                    ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Classes="spacing-tight">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Script directory:"
                           Classes="secondary-text"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.AutomationId="LuaScriptDirectoryTextBox"
                         AutomationProperties.Name="Lua script directory"
                         Text="{Binding LuaScriptDirectory}"
                         IsReadOnly="True"
                         Background="#1A000000"
                         Width="250"
                         HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="The directory from which Lua scripts are loaded. To change it, modify appsettings.json file and restart the application."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
              </Grid>

              <!-- Browser: Store Prefix -->
              <Grid IsVisible="{Binding IsRunningInWebAssembly}"
                    ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Classes="spacing-tight">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Store prefix:"
                           Classes="secondary-text"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.AutomationId="LuaStorePrefixTextBox"
                         AutomationProperties.Name="Lua store prefix"
                         Text="{Binding LuaStorePrefix}"
                         IsReadOnly="True"
                         Background="#1A000000"
                         Width="250"
                         HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="The localStorage key prefix used for Lua script storage."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
              </Grid>

              <!-- Browser: Allow URL-driven scripts -->
              <StackPanel IsVisible="{Binding IsRunningInWebAssembly}" Classes="spacing-tight">
                <CheckBox AutomationProperties.AutomationId="AllowUrlScriptsCheckBox"
                          AutomationProperties.Name="Allow URL-driven scripts"
                          Content="Allow URL-driven scripts (script / scriptUrl query params)"
                          IsChecked="{Binding AllowUrlScripts}"/>
                <TextBlock Text="When enabled, the 'script' (base64url-encoded inline Lua) and 'scriptUrl' query parameters are honoured at startup. Disabled by default — a crafted link can otherwise execute Lua against this emulator and its localStorage. Takes effect on the next page load."
                           Classes="small secondary-text"
                           TextWrapping="Wrap"
                           Margin="20,0,0,0"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Network Section (browser only) -->
        <StackPanel Width="400" Classes="wrap-item"
                    IsVisible="{Binding IsRunningInWebAssembly}">
          <Border Classes="content-section">
            <StackPanel Classes="spacing-tight">
              <TextBlock Text="Network" Classes=""/>

              <TextBlock Text="CORS proxy:" Classes="secondary-text"/>
              <TextBox AutomationProperties.AutomationId="CorsProxyTextBox"
                       AutomationProperties.Name="CORS proxy URL"
                       Text="{Binding CorsProxyUrl, Mode=TwoWay}"
                       PlaceholderText="{Binding CorsProxyUrlWatermark}"/>
              <TextBlock Text="Cross-origin resources (system downloads, and URL-driven startup such as loadPrgUrl / loadD64Url / basicUrl / scriptUrl) are fetched through this CORS proxy. Leave blank to use the built-in default. Browser only — ignored on desktop."
                         Classes="small secondary-text"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>

      </WrapPanel>
    </ScrollViewer>

    <!-- Messages and status in separate row -->
    <StackPanel Grid.Row="2" Classes="spacing-tight">
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource SuccessColor}"
                 TextWrapping="Wrap"
                 IsVisible="{Binding HasStatusMessage}"/>
      
      <!-- Validation Error Messages with Border -->
      <Border Classes="error-container-small"
              IsVisible="{Binding HasValidationErrors}">
        <ItemsControl ItemsSource="{Binding ValidationErrors}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Classes="spacing-tight">
                <TextBlock Text="�" 
                           Classes="error"/>
                <TextBlock Text="{Binding}" 
                           Classes="small"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </StackPanel>

    <!-- Button Section in separate row -->
    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,Auto" Classes="spacing-wide">
      <Button Grid.Column="0"
              AutomationProperties.AutomationId="ResetToDefaultsButton"
              AutomationProperties.Name="Reset to defaults"
              Content="Reset to defaults"
              IsEnabled="{Binding IsNotBusy}"
              Command="{Binding ResetToDefaultsCommand}"/>
      <ProgressBar Grid.Column="1"
                   IsVisible="{Binding IsBusy}"
                   IsIndeterminate="True"/>
      <Button Grid.Column="2"
              AutomationProperties.AutomationId="CancelButton"
              AutomationProperties.Name="Cancel"
              Content="Cancel"
              Classes="cancel"
              Command="{Binding CancelCommand}"/>
      <Button Grid.Column="3"
              AutomationProperties.AutomationId="OkButton"
              AutomationProperties.Name="Save emulator options"
              Content="{Binding OkButtonText}"
              Classes="primary"
              IsDefault="True"
              IsEnabled="{Binding CanSave}"
              Command="{Binding SaveCommand}"/>
    </Grid>

  </Grid>
</UserControl>
