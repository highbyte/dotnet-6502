<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>
  
  <ItemGroup>
    <!-- Fonts and other assets used by Avalonia UI (not emulated systems) -->
    <AvaloniaResource Include="Assets\**" />
    <!-- App logo and favicon sourced from central resources folder -->
    <!-- <AvaloniaResource Include="..\..\..\..\resources\images\logo.png" Link="Assets\logo.png" /> -->
    <AvaloniaResource Include="..\..\..\..\resources\images\logo-simple-text.png" Link="Assets\logo.png" />
    <AvaloniaResource Include="..\..\..\..\resources\images\favicon.ico" Link="Assets\favicon.ico" />
    <!-- Fonts used for rendering emulated systems (not UI) -->
    <AvaloniaResource Include="Resources\Fonts\*.ttf" />
  </ItemGroup>
  
  <ItemGroup>
    <None Remove="Resources\Sample6502Programs\Assembler\C64\scroller_and_raster.prg" />
    <None Remove="Resources\Sample6502Programs\Assembler\C64\smooth_scroller_and_raster.prg" />
    <None Remove="Resources\Sample6502Programs\Basic\C64\HelloWorld.prg" />
    <None Remove="Resources\Sample6502Programs\Basic\C64\PlaySoundVoice1TriangleScale.prg" />
  </ItemGroup>

  <!-- C64 sample programs -->
  <ItemGroup>
    <EmbeddedResource Include="Resources\Sample6502Programs\Assembler\C64\scroller_and_raster.prg" />
    <EmbeddedResource Include="Resources\Sample6502Programs\Assembler\C64\smooth_scroller_and_raster.prg" />
    <EmbeddedResource Include="Resources\Sample6502Programs\Basic\C64\HelloWorld.prg" />
    <EmbeddedResource Include="Resources\Sample6502Programs\Basic\C64\PlaySoundVoice1TriangleScale.prg" />
  </ItemGroup>

  <!-- Generic 6502 sample programs -->
  <ItemGroup>
    <EmbeddedResource Include="Resources\Sample6502Programs\Assembler\Generic\hostinteraction_scroll_text_and_cycle_colors.prg" />
    <EmbeddedResource Include="Resources\Sample6502Programs\Assembler\Generic\snake6502.prg" />
    <EmbeddedResource Include="Resources\Sample6502Programs\Assembler\Generic\hello_world.prg" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Skia" />
    <!-- TODO: re-add Avalonia.Diagnostics (DEBUG-only DevTools) once a 12.x release is published. -->
    <!-- Avalonia.ReactiveUI was deprecated for v12; we use ReactiveUI core + our own AvaloniaDispatcherScheduler. -->
    <PackageReference Include="ReactiveUI" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="SkiaSharp.NativeAssets.WebAssembly" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.Avalonia\Highbyte.DotNet6502.Impl.Avalonia.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502\Highbyte.DotNet6502.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Monitor\Highbyte.DotNet6502.Monitor.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.DebugAdapter\Highbyte.DotNet6502.DebugAdapter.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Remoting\Highbyte.DotNet6502.Remoting.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.Skia\Highbyte.DotNet6502.Impl.Skia.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Systems\Highbyte.DotNet6502.Systems.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Systems.Commodore64\Highbyte.DotNet6502.Systems.Commodore64.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.NAudio\Highbyte.DotNet6502.Impl.NAudio.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Views\DebugSoundUserControl.axaml.cs">
      <DependentUpon>DebugSoundUserControl.axaml</DependentUpon>
    </Compile>
    <Compile Update="Views\C64InfoView.axaml.cs">
      <DependentUpon>C64InfoView.axaml</DependentUpon>
    </Compile>
    <Compile Update="Views\EmulatorPlaceholderView.axaml.cs">
      <DependentUpon>EmulatorPlaceholderView.axaml</DependentUpon>
    </Compile>
    <Compile Update="Views\EmulatorView.axaml.cs">
      <DependentUpon>EmulatorView.axaml</DependentUpon>
    </Compile>
    <Compile Update="Views\ErrorUserControl.axaml.cs">
      <DependentUpon>ErrorUserControl.axaml</DependentUpon>
    </Compile>
  </ItemGroup>
</Project>
