<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Highbyte.DotNet6502.App.Avalonia.Core"
             x:Class="Highbyte.DotNet6502.App.Avalonia.Core.App"
             Name="DotNet 6502 Emulator"
             RequestedThemeVariant="Dark">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <!-- Application-wide shared resources -->
    <Application.Resources>
        <SolidColorBrush x:Key="ViewDefaultBg">#1A202C</SolidColorBrush>
        <SolidColorBrush x:Key="PrimaryBg">#1A2332</SolidColorBrush>
        <SolidColorBrush x:Key="SecondaryBg">#2A3544</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBg">#3A4556</SolidColorBrush>
        <SolidColorBrush x:Key="PrimaryText">#E8EEF5</SolidColorBrush>
        <SolidColorBrush x:Key="SecondaryText">#8B9BB0</SolidColorBrush>
        <SolidColorBrush x:Key="HighlightGold">#B8A876</SolidColorBrush>
        <SolidColorBrush x:Key="AccentBlue">#6B8CAE</SolidColorBrush>
        <SolidColorBrush x:Key="SuccessColor">#5B8A7D</SolidColorBrush>
        <SolidColorBrush x:Key="WarningColor">#B89D5F</SolidColorBrush>
        <SolidColorBrush x:Key="DangerColor">#A85E5E</SolidColorBrush>
        <SolidColorBrush x:Key="BorderColor">#4A5566</SolidColorBrush>
        <FontFamily x:Key="UiFontFamily">avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraSans-Regular.ttf#Fira Sans, avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraSans-SemiBold.ttf#Fira Sans, avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraSans-Bold.ttf#Fira Sans</FontFamily>
        <FontFamily x:Key="MonospaceFontFamily">avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraCode-Regular.ttf#Fira Code, avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraCode-SemiBold.ttf#Fira Code, avares://Highbyte.DotNet6502.App.Avalonia.Core/Assets/Fonts/FiraCode-Bold.ttf#Fira Code</FontFamily>

    </Application.Resources>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Dark" Accent="#6B8CAE" />
            </FluentTheme.Palettes>
        </FluentTheme>

        <!-- Include style files organized by control type -->
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/TextStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/ButtonStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/InputStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/LayoutStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/TableStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/ItemsControlStyles.axaml"/>
        <StyleInclude Source="avares://Highbyte.DotNet6502.App.Avalonia.Core/Styles/UtilityStyles.axaml"/>

        <!-- Override FluentTheme default colors -->
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}"/>
            <Setter Property="Background" Value="{DynamicResource ViewDefaultBg}"/>
        </Style>

    </Application.Styles>
</Application>
