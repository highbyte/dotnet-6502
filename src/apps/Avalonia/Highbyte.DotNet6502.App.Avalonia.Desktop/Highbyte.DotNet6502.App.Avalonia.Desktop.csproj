<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!--If you are willing to use Windows/MacOS native APIs you will need to create 3 projects.
    One for Windows with net10.0-windows TFM, one for MacOS with net10.0-macos and one with net10.0 TFM for Linux.-->
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <UserSecretsId>111df26c-165e-489c-9fbf-0d96435b1972</UserSecretsId>
  </PropertyGroup>

  <PropertyGroup>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>..\..\..\..\resources\images\favicon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" />
    <!-- TODO: re-add Avalonia.Diagnostics (DEBUG-only DevTools) once a 12.x release is published. -->

    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.Configuration.FileExtensions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.UserSecrets" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <!-- Linux native assets must be explicitly included (Win32/macOS are transitive dependencies of SkiaSharp) -->
    <PackageReference Include="SkiaSharp.NativeAssets.Linux" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.App.Avalonia.Core\Highbyte.DotNet6502.App.Avalonia.Core.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Updates\Highbyte.DotNet6502.Updates.csproj" />
    <!-- Convention glob: every per-system shell is deployed for SystemPluginDiscovery without
         editing this entry exe when a new system is added. -->
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\Highbyte.DotNet6502.App.Avalonia.Shell.*\*.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Impl.SilkNet.SDL\Highbyte.DotNet6502.Impl.SilkNet.SDL.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.DebugAdapter\Highbyte.DotNet6502.DebugAdapter.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Remoting\Highbyte.DotNet6502.Remoting.csproj" />
    <ProjectReference Include="..\..\..\libraries\Highbyte.DotNet6502.Scripting.MoonSharp\Highbyte.DotNet6502.Scripting.MoonSharp.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.Development.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Never</CopyToPublishDirectory>
    </None>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!--
    Plug-in discovery manifest (single-file publish).
    SystemPluginDiscovery loads plug-in assemblies by (a) a transitive reference walk from the
    entry assembly, (b) a scan of the output directory, and (c) an assembly-metadata manifest.
    With PublishSingleFile=true (the publish path for this exe) the plug-in DLLs are bundled
    inside the single-file exe, so (b) finds nothing; and the entry exe holds no static
    reference to any per-system plug-in type, so the C# compiler prunes the ProjectReferences
    and (a) finds nothing either.
    This target emits, into the entry assembly, one
    [assembly: AssemblyMetadata("Highbyte.DotNet6502.PluginAssembly", "<name>")] per
    Highbyte.DotNet6502.* assembly in the resolved reference closure (direct + transitive).
    SystemPluginDiscovery reads that manifest and Assembly.Loads each by name. Convention-based:
    adding a new system needs no edit here.
  -->
  <Target Name="EmitPluginAssemblyManifest"
          DependsOnTargets="ResolveReferences"
          BeforeTargets="GetAssemblyAttributes">
    <ItemGroup>
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferencePath.FileName)"
                        Condition="$([System.String]::Copy('%(ReferencePath.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
      <AssemblyMetadata Include="Highbyte.DotNet6502.PluginAssembly"
                        Value="%(ReferenceDependencyPaths.FileName)"
                        Condition="$([System.String]::Copy('%(ReferenceDependencyPaths.FileName)').StartsWith('Highbyte.DotNet6502.'))" />
    </ItemGroup>
  </Target>

  <!-- Copy Lua example scripts from central resources location to output directory -->
  <Target Name="CopyExampleScripts" AfterTargets="AfterBuild">
    <ItemGroup>
      <_SharedScripts Include="$(MSBuildThisFileDirectory)..\..\..\..\resources\scripts\shared\*" />
      <_DesktopScripts Include="$(MSBuildThisFileDirectory)..\..\..\..\resources\scripts\desktop\*" />
      <_OldOutputExampleScripts Include="$(OutDir)scripts\example_*.lua" />
    </ItemGroup>
    <Delete Files="@(_OldOutputExampleScripts)" />
    <Copy SourceFiles="@(_SharedScripts)" DestinationFolder="$(OutDir)example-scripts" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_DesktopScripts)" DestinationFolder="$(OutDir)example-scripts" SkipUnchangedFiles="true" />
  </Target>
</Project>
