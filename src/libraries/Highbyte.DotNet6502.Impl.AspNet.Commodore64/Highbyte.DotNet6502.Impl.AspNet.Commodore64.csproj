<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>Highbyte.DotNet6502.Impl.AspNet.Commodore64</PackageId>
    <Authors>Highbyte</Authors>
    <PackageDescription>ASP.NET Commodore 64 support library for Highbyte.DotNet6502 CPU emulator.</PackageDescription>
    <RepositoryUrl>https://github.com/highbyte/dotnet-6502</RepositoryUrl>
    <Version>0.1.0-alpha</Version>

    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" />
    <!-- Blazored.LocalStorage: C64Setup reads/writes host config via BrowserContext.LocalStorage. -->
    <PackageReference Include="Blazored.LocalStorage" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.Impl.AspNet\Highbyte.DotNet6502.Impl.AspNet.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Impl.Skia.Commodore64\Highbyte.DotNet6502.Impl.Skia.Commodore64.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.AI\Highbyte.DotNet6502.AI.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems.Commodore64\Highbyte.DotNet6502.Systems.Commodore64.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems.Plugins\Highbyte.DotNet6502.Systems.Plugins.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502\Highbyte.DotNet6502.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems\Highbyte.DotNet6502.Systems.csproj" />
  </ItemGroup>

</Project>
