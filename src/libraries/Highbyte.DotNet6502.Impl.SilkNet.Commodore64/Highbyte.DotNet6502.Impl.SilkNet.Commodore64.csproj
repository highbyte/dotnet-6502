<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <PackageId>Highbyte.DotNet6502.Impl.SilkNet.Commodore64</PackageId>
    <Authors>Highbyte</Authors>
    <PackageDescription>A SilkNet Commodore 64 support library for running 6502 code in Highbyte.DotNet6502 CPU emulator.</PackageDescription>
    <RepositoryUrl>https://github.com/highbyte/dotnet-6502</RepositoryUrl>
    <Version>0.1.0-alpha</Version>

    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Highbyte.DotNet6502.Impl.SilkNet\Highbyte.DotNet6502.Impl.SilkNet.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Impl.Skia.Commodore64\Highbyte.DotNet6502.Impl.Skia.Commodore64.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Impl.NAudio\Highbyte.DotNet6502.Impl.NAudio.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems.Commodore64\Highbyte.DotNet6502.Systems.Commodore64.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems.Plugins\Highbyte.DotNet6502.Systems.Plugins.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502\Highbyte.DotNet6502.csproj" />
    <ProjectReference Include="..\Highbyte.DotNet6502.Systems\Highbyte.DotNet6502.Systems.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Silk.NET.Input" />
    <PackageReference Include="Silk.NET.OpenGL" />
    <!-- Configuration.Binder: C64Setup binds the host config section from appsettings.json. -->
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Commodore64\Render\C64shader.frag" />
    <EmbeddedResource Include="Commodore64\Render\C64shader.vert" />
  </ItemGroup>

</Project>
